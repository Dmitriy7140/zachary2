# --- Telegram ---
BOT_TOKEN=
ADMIN_ID=            # твой личный TG id (куда падают заявки на регистрацию)
CHANNEL_ID=          # id канала/супергруппы с тредом приветствий
THREAD_ID=           # id треда (forum topic) для приветствий; пусто = без треда

# --- Minecraft RCON ---
RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PASSWORD=

# --- Прочее ---
POLL_INTERVAL=20     # как часто (сек) опрашивать сервер на новых игроков
DB_PATH=zachary.db

# --- Куб ---
CUBE_RESET_MINUTES=60              # полный срок поколения, включая набор
CUBE_LOBBY_SECONDS=180             # сколько секунд можно присоединяться после первого входа
CUBE_ENTRY_COST=500                # стоимость входа в Z
CUBE_PRIZE_PER_PARTICIPANT=1000    # множитель джекпота на участника
CUBE_MAX_PARTICIPANTS=16           # от 1 до 16 игроков
